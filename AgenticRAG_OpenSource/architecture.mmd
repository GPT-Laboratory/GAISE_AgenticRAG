%% Agentic RAG — simple architecture pattern
%% Render at https://mermaid.live or with: mmdc -i architecture.mmd -o architecture.svg
flowchart TB
    A["User asks question in UI"] --> B["Chatbot Interface (FastAPI)"]
    B --> C["LLM Agent (LangGraph)"]
    C --> D{"Need data or documents?"}
    D -- "Yes" --> E["Tool Call"]
    E --> G["Backend Module<br>Analytics / Retrieval"]
    G --> H["Data Access Layer"]
    H --> I["Trusted Dataset<br>clean tables + document index"]
    I --> J["Compute / Vector Search"]
    J --> K["Structured Result"]
    K --> L["Return result to Agent"]
    L --> C
    D -- "No · has enough" --> M["Agent writes final answer"]
    M --> P["Finalize<br>force English · remove inline citations"]
    P --> N["Display answer + chart<br>(sources shown in side panel)"]
